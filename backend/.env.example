# Deja DATABASE_URL vacío para usar SQLite local (misiondino.db).
# En Railway se define automáticamente al agregar el plugin de PostgreSQL.
DATABASE_URL=

# Orígenes permitidos para CORS (separados por coma). El dominio de Vercel va aquí.
CORS_ORIGINS=http://localhost:5173

# Fechas del juego (ISO). El reto corre entre estas fechas, inclusive.
GAME_START_DATE=2026-07-07
GAME_END_DATE=2026-08-15

CHILD_NAME=Ángel Eduardo
